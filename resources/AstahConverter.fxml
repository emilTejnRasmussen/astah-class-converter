<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="724.0" prefWidth="1059.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.controller.AstahConverterController">
    <TextArea fx:id="inputTextArea" prefHeight="724.0" prefWidth="908.0" HBox.hgrow="ALWAYS" />
    <VBox minWidth="300.0" prefHeight="200.0" prefWidth="100.0" spacing="20.0">
        <padding>
            <Insets bottom="40.0" left="20.0" right="20.0" top="40.0" />
        </padding>
        <Label prefWidth="9999.0" text="Astah Converter">
            <font>
                <Font name="Segoe UI Semibold" size="24.0" />
            </font>
        </Label>
        <VBox prefWidth="100.0" spacing="5.0">
            <CheckBox fx:id="privateMethodsCheckBox" mnemonicParsing="false" onMouseClicked="#handleCheckBoxPressed" text="include private methods" />
        </VBox>
        <Button mnemonicParsing="false" onAction="#convertPressed" prefHeight="40.0" prefWidth="99999.0" text="convert">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Label fx:id="infoLbl" text="INFO LABEL" />
        <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
        <Label prefWidth="9999.0" text="ClassName:">
            <font>
                <Font name="Segoe UI Semibold" size="18.0" />
            </font>
        </Label>
      <Label fx:id="classNameLbl" prefWidth="9999.0">
         <font>
            <Font name="Segoe UI Semibold" size="18.0" />
         </font>
      </Label>
      <Button fx:id="copyClassNameBtn" mnemonicParsing="false" onAction="#copyClassNamePressed" prefHeight="40.0" prefWidth="99999.0" text="copy class name">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
        <Button fx:id="copyAttributesBtn" mnemonicParsing="false" onAction="#copyAttributesPressed" prefHeight="40.0" prefWidth="99999.0" text="copy attributes">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Button fx:id="copyOperationsBtn" mnemonicParsing="false" onAction="#copyOperationsPressed" prefHeight="40.0" prefWidth="99999.0" text="copy operations">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
    </VBox>
</HBox>
